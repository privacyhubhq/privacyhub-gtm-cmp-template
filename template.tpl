scenarios:
- name: Fail when websiteId is missing
  code: |-
    const mockData = {
      scriptUrl: 'https://api.privacyhub.ai/functions/v1/ph',
      debugMode: false,
      preventDuplicateLoads: true,
      waitForUpdate: 500
    };

    runCode(mockData);

    assertApi('gtmOnFailure').wasCalled();
- name: Init sets default denied consent
  code: |-
    mock('injectScript', function(url, onSuccess, onFailure) {
      onSuccess();
    });

    mock('getUrl', function(component) {
      return 'cdsglobal.ae';
    });

    const mockData = {
      websiteId: 'a9332dbd-0403-4270-8de8-f8126c614250',
      scriptUrl: 'https://api.privacyhub.ai/functions/v1/ph',
      debugMode: false,
      preventDuplicateLoads: false,
      waitForUpdate: 500
    };

    runCode(mockData);

    assertApi('setDefaultConsentState').wasCalledWith({
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      analytics_storage: 'denied',
