___SANDBOXED_JS_FOR_WEB_TEMPLATE___

/*
PrivacyHub CMP (Official) - GTM Customer Template Code
Version: 3.1.0
Mode: One Tag GTM Template Mode

Customer setup:
1) Create ONE PrivacyHub CMP tag
2) Tag Mode: auto
3) Add TWO triggers:
   - Consent Initialization - All Pages
   - Custom Event: ph_consent_updated
*/

const injectScript = require('injectScript');
const createQueue = require('createQueue');
const log = require('logToConsole');
const encodeUriComponent = require('encodeUriComponent');
const makeNumber = require('makeNumber');
const copyFromDataLayer = require('copyFromDataLayer');
const setDefaultConsentState = require('setDefaultConsentState');
const updateConsentState = require('updateConsentState');
const templateStorage = require('templateStorage');
const getUrl = require('getUrl');
const callLater = require('callLater');
const gtagSet = require('gtagSet');

const websiteId = data.websiteId;
const scriptUrl = data.scriptUrl || 'https://api.privacyhub.ai/functions/v1/ph';
const tagMode = data.tagMode || 'auto';
const debugMode = data.debugMode === true;
const preventDuplicateLoads = data.preventDuplicateLoads !== false;

const waitForUpdateRaw = makeNumber(data.waitForUpdate);
const waitForUpdateMs =
  waitForUpdateRaw && waitForUpdateRaw > 0 ? waitForUpdateRaw : 500;

const emitRecoveryEvents = data.emitRecoveryEvents !== false;
const emitAdsReadyEvent = data.emitAdsReadyEvent !== false;

/*
IMPORTANT:
Replace this only with the official Google-issued Developer ID for PrivacyHub.
Do not invent one.
Example format usually looks like developer_id.xxxxxxxx.
*/
const privacyhubDeveloperId = 'dYzJiYm';

function debug(message, extra) {
  if (!debugMode) return;
  log('[PrivacyHub CMP Template] ' + message);
  if (extra !== undefined) log(extra);
}

function done() {
  data.gtmOnSuccess();
}

function fail() {
  data.gtmOnFailure();
}

function defaultConsentState() {
  return {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    analytics_storage: 'denied',
    functionality_storage: 'granted',
    personalization_storage: 'denied',
    security_storage: 'granted',
    wait_for_update: waitForUpdateMs
  };
}

function normalizeConsent(update) {
  if (!update) return null;

  return {
    ad_storage: update.ad_storage === 'granted' ? 'granted' : 'denied',
    ad_user_data: update.ad_user_data === 'granted' ? 'granted' : 'denied',
    ad_personalization: update.ad_personalization === 'granted' ? 'granted' : 'denied',
    analytics_storage: update.analytics_storage === 'granted' ? 'granted' : 'denied',
    functionality_storage: update.functionality_storage === 'denied' ? 'denied' : 'granted',
    personalization_storage: update.personalization_storage === 'granted' ? 'granted' : 'denied',
    security_storage: update.security_storage === 'denied' ? 'denied' : 'granted'
  };
}

function consentHash(update) {
  return update.ad_storage + '|' +
    update.ad_user_data + '|' +
    update.ad_personalization + '|' +
    update.analytics_storage + '|' +
    update.functionality_storage + '|' +
    update.personalization_storage + '|' +
    update.security_storage;
}

function pushDataLayerEvent(eventName, payload) {
  const queue = createQueue('dataLayer');
  payload = payload || {};
  payload.event = eventName;
  payload.privacyhub_website_id = websiteId;
  payload.source = payload.source || 'privacyhub_gtm_template';
  queue(payload);
}

function getPageHost() {
  return getUrl('host') || '';
}

function analyticsGranted(update) {
  return update && update.analytics_storage === 'granted';
}

function adsGranted(update) {
  return update &&
    update.ad_storage === 'granted' &&
    update.ad_user_data === 'granted' &&
    update.ad_personalization === 'granted';
}

function emitOptionalPostConsentEvents(update) {
  if (!emitRecoveryEvents) return;

  if (analyticsGranted(update)) {
    pushDataLayerEvent('privacyhub_google_tag_init_after_consent', {
      consent_update: update,
      analytics_storage: update.analytics_storage
    });

    callLater(function () {
      pushDataLayerEvent('privacyhub_ga4_page_view_after_consent', {
        consent_update: update,
        analytics_storage: update.analytics_storage
      });
    });
  }

  if (emitAdsReadyEvent && adsGranted(update)) {
    callLater(function () {
      pushDataLayerEvent('privacyhub_ads_ready_after_consent', {
        consent_update: update,
        ad_storage: update.ad_storage,
        ad_user_data: update.ad_user_data,
        ad_personalization: update.ad_personalization
      });
    });
  }
}

function applyConsentUpdate() {
  const consentUpdateFromDataLayer = copyFromDataLayer('consent_update');
  const update = normalizeConsent(consentUpdateFromDataLayer);

  if (!update) {
    debug('No consent_update found. Running init path.');
    return false;
  }

  const hash = consentHash(update);

  if (templateStorage.getItem('lastConsentHash') === hash) {
    debug('Duplicate consent update ignored.');
    done();
    return true;
  }

  templateStorage.setItem('lastConsentHash', hash);

  updateConsentState(update);

  pushDataLayerEvent('privacyhub_gtm_consent_applied', {
    consent_update: update
  });

  emitOptionalPostConsentEvents(update);

  debug('Consent state updated from PrivacyHub event.', update);
  done();
  return true;
}

function runInit() {
  if (preventDuplicateLoads && templateStorage.getItem('cmpLoaded') === true) {
    debug('PrivacyHub CMP already loaded. Skipping duplicate load.');
    done();
    return;
  }

  if (preventDuplicateLoads) {
    templateStorage.setItem('cmpLoaded', true);
  }

  const defaults = defaultConsentState();

  setDefaultConsentState(defaults);

if (
  privacyhubDeveloperId &&
  privacyhubDeveloperId !== 'YOUR_GOOGLE_ISSUED_DEVELOPER_ID'
) {
  const developerPayload = {
    developer_id: {}
  };

  developerPayload.developer_id[privacyhubDeveloperId] = true;

  gtagSet(developerPayload);
}

  pushDataLayerEvent('privacyhub_gcm_initialized', {
    wait_for_update: waitForUpdateMs,
    consent_default: defaults
  });

  debug('Default consent state applied.', defaults);

  const pageHost = getPageHost();

  let finalUrl = scriptUrl +
    '?websiteId=' + encodeUriComponent(websiteId) +
    '&ph_gtm_template_mode=1' +
    '&gcm=true';

  if (pageHost) {
    finalUrl += '&pageHost=' + encodeUriComponent(pageHost);
  }

  if (debugMode) {
    finalUrl += '&debug=true';
  }

  debug('Loading PrivacyHub CMP script.', finalUrl);

  injectScript(
    finalUrl,
    function () {
      debug('PrivacyHub CMP loaded successfully.');
      done();
    },
    function () {
      debug('PrivacyHub CMP failed to load.');
      fail();
    }
  );
}

if (!websiteId) {
  debug('Missing PrivacyHub Website ID.');
  fail();
  return;
}

if (tagMode === 'consent_update') {
  applyConsentUpdate();
  return;
}

if (tagMode === 'init') {
  runInit();
  return;
}

/*
Auto mode:
- On Consent Initialization, no consent_update exists, so init runs.
- On ph_consent_updated, consent_update exists, so update runs.
*/
if (tagMode === 'auto') {
  if (applyConsentUpdate()) {
    return;
  }

  runInit();
  return;
}

debug('Unknown tagMode: ' + tagMode);
done();


